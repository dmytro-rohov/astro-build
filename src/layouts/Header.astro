---
import Container from "@/components/layouts/Container.astro";
import Navbar, { type NavItem, type NavAction } from "@/components/widgets/Navbar.astro";

export interface Props {
  brandLabel?: string;
  brandHref?: string;
  navItems?: NavItem[];
  cta?: NavAction;
  sticky?: boolean;
  class?: string;
}

const defaultNavItems: NavItem[] = [
  { label: "Home", href: "/" },
  { label: "Features", href: "/#features" },
  { label: "Components", href: "/playground" },
  { label: "Contact", href: "/contact" },
];

const {
  brandLabel = "Astro System",
  brandHref = "/",
  navItems = defaultNavItems,
  cta,
  sticky = true,
  class: className,
  ...restProps
} = Astro.props;
---

<header
  {...restProps}
  class:list={[
    "site-header",
    sticky && "site-header--sticky",
    className,
  ]}
>
  <Container size="xl">
    <div class="site-header__inner">
      <a class="site-header__brand" href={brandHref}>
        {brandLabel}
      </a>

      <Navbar items={navItems} cta={cta} />
    </div>
  </Container>
</header>