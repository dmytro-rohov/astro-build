---
type SidebarTag = "aside" | "div" | "section" | "main";

export interface Props {
  as?: SidebarTag;
  side?: "left" | "right";
  width?: string;
  gap?: "md" | "lg" | "xl" | "2xl" | string;
  class?: string;
}

const {
  as: Tag = "div",
  side = "right",
  width = "20rem",
  gap = "xl",
  class: className,
  ...restProps
} = Astro.props;

const tokenGap = gap.startsWith("var(")
  ? gap
  : gap.includes("rem") || gap.includes("px")
    ? gap
    : `var(--spacing-${gap})`;
---

<Tag
  {...restProps}
  class:list={[
    "sidebar",
    `sidebar--${side}`,
    className,
  ]}
  style={`--sidebar-width: ${width}; --sidebar-gap: ${tokenGap};`}
>
  <slot />
</Tag>