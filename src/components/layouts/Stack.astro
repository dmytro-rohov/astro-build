---
type StackTag = "div" | "section" | "article" | "ul" | "ol" | "form";

export interface Props {
  as?: StackTag;
  space?: "xs" | "sm" | "md" | "lg" | "xl" | "2xl" | string;
  class?: string;
}

const {
  as: Tag = "div",
  space = "md",
  class: className,
  ...restProps
} = Astro.props;

const tokensSpace = space.startsWith("var(") ? space : space.includes("rem") || space.includes("px") ? space : `var(--spacing-${space})`;
---

<Tag
{...restProps}
class:list={[
  "stack",
  className,
]} styles={`--stack-space: ${tokensSpace};`} >

<slot />

</Tag>