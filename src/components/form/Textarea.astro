---
export interface Props {
  id?: string;
  name?: string;
  value?: string;
  placeholder?: string;
  rows?: number;
  required?: boolean;
  disabled?: boolean;
  readonly?: boolean;
  invalid?: boolean;
  describedby?: string;
  class?: string;
}

const {
  id,
  name,
  value,
  placeholder,
  rows = 5,
  required = false,
  disabled = false,
  readonly = false,
  invalid = false,
  describedby,
  class: className,
  ...restProps
} = Astro.props;
---

<textarea
  {...restProps}
  id={id}
  name={name}
  placeholder={placeholder}
  rows={rows}
  required={required}
  disabled={disabled}
  readonly={readonly}
  aria-invalid={invalid ? "true" : undefined}
  aria-describedby={describedby}
  class:list={[
    "textarea",
    invalid && "textarea--invalid",
    className,
  ]}
>{value}</textarea>