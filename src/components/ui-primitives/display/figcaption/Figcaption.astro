---
import Img, { type ImgProps } from "./Img.astro";

export interface FigureProps extends ImgProps {
  caption?: string;
  captionPosition?: "top" | "bottom";
}

const {
  caption,
  captionPosition = "bottom",
  kind = "content",
  ...imgProps
} = Astro.props;

if (import.meta.env.DEV && kind === "decorative") {
  console.warn("[Figure] Decorative images should not use <figure>");
}
---

<figure class="figure">
  {caption && captionPosition === "top" && (
    <figcaption class="figure__caption">
      {caption}
    </figcaption>
  )}

  <Img kind={kind} {...imgProps} />

  {caption && captionPosition === "bottom" && (
    <figcaption class="figure__caption">
      {caption}
    </figcaption>
  )}
</figure>
