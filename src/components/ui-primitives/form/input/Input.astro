---
import "./input.scss";

interface Props {
  id?: string
  type?: string
  name?: string
  value?: string
  placeholder?: string
  size?: "sm" | "md" | "lg"
  disabled?: boolean
  required?: boolean
  invalid?: boolean
}

const {
  id,
  type = "text",
  name,
  value,
  placeholder,
  size = "md",
  disabled = false,
  required = false,
  invalid = false
} = Astro.props;
---

<input
  id={id}
  class="input"
  data-size={size}
  type={type}
  name={name}
  value={value}
  placeholder={placeholder}
  disabled={disabled}
  required={required}
  aria-invalid={invalid}
/>