---

import BaseLayout from "@/layouts/BaseLayout.astro";

import Button from "@/components/ui/Button.astro";
import Tag from "@/components/ui/Tag.astro";
import Card from "@/components/ui/Card.astro";
import Link from "@/components/ui/Link.astro";
import Img from "@/components/media/Img.astro";

import FormGroup from "@/components/form/FormGroup.astro";
import FormField from "@/components/form/FormField.astro";
import Label from "@/components/form/Label.astro";
import FieldHint from "@/components/form/FieldHint.astro";
import Input from "@/components/form/Input.astro";
import Textarea from "@/components/form/Textarea.astro";
import Checkbox from "@/components/form/Checkbox.astro";
import Button from "@/components/ui/Button.astro";  

import Section from "@/components/layouts/Section.astro";
import Container from "@/components/layouts/Container.astro";
import Split from "@/components/layouts/Split.astro";
import Stack from "@/components/layouts/Stack.astro";
import Cluster from "@/components/layouts/Cluster.astro";
import Grid from "@/components/layouts/Grid.astro";

import Hero from "@/components/widgets/Hero.astro";
import FeatureGrid from "@/components/widgets/FeatureGrid.astro";

import heroImage from "@/assets/img/photo.jpg";


const features = [
  {
    eyebrow: "Tokens",
    title: "Design tokens",
    description: "Centralized values for colors, spacing, typography, radius, shadows and motion.",
  },
  {
    eyebrow: "Media",
    title: "Optimized images",
    description: "Reusable Img and Picture components with Astro image optimization and sensible defaults.",
  },
  {
    eyebrow: "Icons",
    title: "SVG sprite",
    description: "A local SVG sprite pipeline for optimized and reusable icons.",
  },
  {
    eyebrow: "Layout",
    title: "Layout primitives",
    description: "Container, Section, Stack, Cluster, Grid, Split and Sidebar for consistent page structure.",
  },
  {
    eyebrow: "Fonts",
    title: "Local fonts",
    description: "A local font pipeline with generated @font-face rules and subset support.",
  },
  {
    eyebrow: "SCSS",
    title: "Clean architecture",
    description: "Global SCSS layers, reusable components and no duplicated local CSS files.",
  },
];

---

<BaseLayout
  title="Astro System Landing"
  description="Reusable Astro starter for professional landing pages."
>

  <Hero
    eyebrow="Astro Frontend System"
    title="Build landing pages faster."
    description="Reusable Astro components, design tokens, optimized media, local fonts and clean SCSS architecture."
    image={heroImage}
    imageAlt="Preview of a modern landing page"
    primaryAction={{
      label: "Get started",
      href: "/#features",
    }}
    secondaryAction={{
      label: "View components",
      href: "/playground",
    }}
  />

  <FeatureGrid
    eyebrow="Features"
    title="Everything needed for modern landing pages."
    description="A reusable Astro system with clean primitives, optimized assets and a predictable styling workflow."
    items={features}
  />
    

  <Section>
    <Container size="lg">
      <Stack space="var(--spacing-lg)">
        <p>Astro Frontend System</p>

        <h1>Build professional landing pages faster.</h1>

        <p>
          A reusable Astro template with media optimization, design tokens,
          local fonts, SVG icons, layout primitives and production-ready structure.
        </p>

        <Cluster gap="var(--spacing-md)">
          <Button>Get started</Button>
          <Button variant="secondary">View components</Button>
        </Cluster>
      </Stack>

<form class="contact-form" action="#" method="post">
  <FormGroup gap="lg">
    <FormField>
      <Label for="name" required>Name</Label>
      <Input id="name" name="name" required autocomplete="name" />
    </FormField>

    <FormField>
      <Label for="email" required>Email</Label>
      <Input
        id="email"
        name="email"
        type="email"
        required
        autocomplete="email"
        describedby="email-hint"
      />
      <FieldHint id="email-hint">
        We will reply to this address.
      </FieldHint>
    </FormField>

    <FormField>
      <Label for="message" required>Message</Label>
      <Textarea id="message" name="message" required rows={6} />
    </FormField>

    <Checkbox id="privacy" name="privacy" required>
      I accept the privacy policy.
    </Checkbox>

    <Button type="submit">
      Send message
    </Button>
  </FormGroup>
</form>

    </Container>
  </Section>

  <Container size="xl">
    <Split ratio="text-media" gap="2xl">
      <Stack space="lg">
        <Tag variant="primary">Astro Frontend System</Tag>

        <h1>Build landing pages faster.</h1>

        <p>
          Reusable Astro components, design tokens, local fonts,
          optimized media and clean SCSS architecture.
        </p>

        <Cluster gap="md">
          <Button>Get started</Button>
          <Link href="/components">View components</Link>
        </Cluster>
      </Stack>

      <Img
        src={heroImage}
        alt="Astro landing page preview"
        class="image--rounded image--shadow"
      />
    </Split>
  </Container>
</Section>

<Section tone="muted">
  <Container>
    <Stack space="xl">
      <Stack space="sm">
        <h2>Everything needed for modern landing pages.</h2>
        <p>Start fast with reusable layout and UI primitives.</p>
      </Stack>

      <Grid columns="3">
        <Card as="article">
          <h3>Design tokens</h3>
          <p>Centralized values for color, spacing, typography and motion.</p>
        </Card>

        <Card as="article">
          <h3>Media system</h3>
          <p>Optimized images, picture sources and local SVG sprite icons.</p>
        </Card>

        <Card as="article">
          <h3>Clean SCSS</h3>
          <p>Organized layers, global primitives and no duplicated component CSS.</p>
        </Card>
      </Grid>
    </Stack>
  </Container>
</Section>


</BaseLayout>