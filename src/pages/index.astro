---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Container from "@/components/layouts/Container.astro";
import Section from "@/components/layouts/Section.astro";
import Stack from "@/components/layouts/Stack.astro";
import Cluster from "@/components/layouts/Cluster.astro";

import Button from "@/components/ui/Button.astro";

import FormGroup from "@/components/form/FormGroup.astro";
import FormField from "@/components/form/FormField.astro";
import Label from "@/components/form/Label.astro";
import FieldHint from "@/components/form/FieldHint.astro";
import Input from "@/components/form/Input.astro";
import Textarea from "@/components/form/Textarea.astro";
import Checkbox from "@/components/form/Checkbox.astro";
import Button from "@/components/ui/Button.astro";
---

<BaseLayout
  title="Astro System Landing"
  description="Reusable Astro starter for professional landing pages."
>
  <Section>
    <Container size="lg">
      <Stack space="var(--spacing-lg)">
        <p>Astro Frontend System</p>

        <h1>Build professional landing pages faster.</h1>

        <p>
          A reusable Astro template with media optimization, design tokens,
          local fonts, SVG icons, layout primitives and production-ready structure.
        </p>

        <Cluster gap="var(--spacing-md)">
          <Button>Get started</Button>
          <Button variant="secondary">View components</Button>
        </Cluster>
      </Stack>

<form class="contact-form" action="#" method="post">
  <FormGroup gap="lg">
    <FormField>
      <Label for="name" required>Name</Label>
      <Input id="name" name="name" required autocomplete="name" />
    </FormField>

    <FormField>
      <Label for="email" required>Email</Label>
      <Input
        id="email"
        name="email"
        type="email"
        required
        autocomplete="email"
        describedby="email-hint"
      />
      <FieldHint id="email-hint">
        We will reply to this address.
      </FieldHint>
    </FormField>

    <FormField>
      <Label for="message" required>Message</Label>
      <Textarea id="message" name="message" required rows={6} />
    </FormField>

    <Checkbox id="privacy" name="privacy" required>
      I accept the privacy policy.
    </Checkbox>

    <Button type="submit">
      Send message
    </Button>
  </FormGroup>
</form>

    </Container>
  </Section>
</BaseLayout>